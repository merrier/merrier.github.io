{% if site.categories.length %}
    {% set limit = theme.cate_config.limit or 6 %}
    <div class="widget category-widget">
        <h3 class="title">{{ __('categories') }}</h3>
        
        {% if site.categories.length > limit %}
            {{ list_categories(getCategoriesArgs(theme)) | replace('class="category-list"', 'class="category-list is-collapsed"') | safe }}
            <style>
                .category-list.is-collapsed .category-list-item:nth-child(n+{{ limit + 1 }}) {
                    display: none;
                }
            </style>
            <div class="expand-btn-wrapper" style="text-align: center; margin-top: 15px;">
                <button class="zhui-expand-btn" onclick="this.closest('.widget').querySelector('.category-list').classList.remove('is-collapsed'); this.parentElement.style.display='none';">
                    <svg class="zhui-expand-svg" viewBox="0 0 144 40" width="144" height="40">
                        <path d="M0.5,5.5 L5.5,5.5 L5.5,0.5 L138.5,0.5 L138.5,5.5 L143.5,5.5 L143.5,34.5 L138.5,34.5 L138.5,39.5 L5.5,39.5 L5.5,34.5 L0.5,34.5 Z" fill="none" stroke="currentColor" stroke-width="1"></path>
                    </svg>
                    <span>更多分类内容</span>
                </button>
            </div>
        {% else %}
            {{ list_categories(getCategoriesArgs(theme)) | safe }}
        {% endif %}
    </div>
{% endif %}
